PORT=8787
DB_PATH=./data/tracks.sqlite

# MQTT (Connectlab broker)
MQTT_URL=tls://your-connectlab-broker.example:8883
MQTT_USERNAME=your_username
MQTT_PASSWORD=your_password
MQTT_CLIENT_ID=ride-helmet-server-01
MQTT_TOPIC_PREFIX=ridehelmet

# TLS / CA (optional)
MQTT_REJECT_UNAUTHORIZED=true
MQTT_CA_PATH=./ca.pem

# QoS defaults
MQTT_QOS_TELEMETRY=0
MQTT_QOS_CMD=1

# Command handling
COMMAND_ACK_TIMEOUT_MS=8000

# WebSocket config
WS_PATH=/ws